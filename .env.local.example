# Coordin.io — Environment Variables
# Copy this to .env.local and fill in your credentials

# ── Supabase ─────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional — for server-side operations (Edge Functions, admin)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Email (Resend) ──────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key-here

# Email the team receives when someone signs up for a demo
TEAM_NOTIFICATION_EMAIL=wale@techsanctum.org

# The "from" address for outbound emails (must be verified in Resend)
RESEND_FROM_EMAIL=Coordin.io <noreply@coordin.io>
